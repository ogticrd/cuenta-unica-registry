ORY_SDK_URL=http://localhost:4000
ORY_SDK_TOKEN=ory_pat_
# Public-facing app URL used by @ory/nextjs SDK to proxy Ory requests through the app.
# In production, set to the deployed app URL (e.g., https://your-app.a.run.app).
# Locally, leave unset — the SDK falls back to window.location.origin.
NEXT_PUBLIC_ORY_SDK_URL=
REGISTRATION_SESSION_SECRET=

# Citizens API (shared base URL, separate API keys)
CITIZENS_API_BASE_URL=https://api.devs.digital.gob.do
CITIZENS_INFO_API_KEY=
CITIZENS_PHOTO_API_KEY=

# AWS Rekognition (server-side only)
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# Amplify / Cognito (client-side, required by FaceLivenessDetector)
NEXT_PUBLIC_AWS_REGION=us-east-1
NEXT_PUBLIC_COGNITO_IDENTITY_POOL_ID=
NEXT_PUBLIC_COGNITO_USER_POOL_ID=
NEXT_PUBLIC_COGNITO_USER_POOL_CLIENT_ID=

# Rekognition thresholds (optional, sensible defaults)
LIVENESS_CONFIDENCE_THRESHOLD=90
FACE_SIMILARITY_THRESHOLD=80
