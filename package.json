  "scripts": {
    "build": "next build",
    "dev": "next dev",
    "lint": "tsc --noEmit",
    "typecheck": "tsc --noEmit",
    "start": "next start",
    "check": "biome ci .",
    "format": "biome check --write .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:unit": "vitest run __tests__/unit",
    "test:components": "vitest run __tests__/components",
    "test:integration": "vitest run __tests__/integration",
    "test:e2e": "vitest run __tests__/e2e",
    "test:validation": "vitest run __tests__/validation",
    "test:hooks": "vitest run __tests__/hooks",
    "test:actions": "vitest run __tests__/actions",
    "test:middleware": "vitest run __tests__/middleware",
    "test:playwright": "playwright test",
    "test:playwright:ui": "playwright test --ui",
    "test:playwright:debug": "playwright test --debug",
    "test:all": "vitest run && playwright test",
    "test:ui": "vitest --ui"
  },
