{
  "name": "cuenta-unica-ciudadana",
  "description": "Cuenta Única Ciudadana, gestión de identidad digital dominicana.",
  "version": "2.0.0",
  "author": "OGTIC",
  "private": true,
  "packageManager": "bun@1.3.11",
  "engines": {
    "node": ">=20.9.0",
    "bun": ">=1.3.11"
